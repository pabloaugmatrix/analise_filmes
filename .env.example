# ==============================================================================
# SECRETS - NUNCA commitar este arquivo (.gitignore ja bloqueia)
# Copie para .env e preencha com sua chave do TMDB
# Obtenha em: https://www.themoviedb.org/settings/api
# ==============================================================================
TMDB_API_KEY=sua_chave_de_32_caracteres_aqui

# (Opcional) Chave da API publica do BLS - eleva o limite de consultas diarias
# para o ajuste inflacionario (CPI). Obtenha em: https://data.bls.gov/registrationEngine/
# Se ausente, o pipeline usa a API gratuita (limite menor) ou o fallback estatico.
BLS_API_KEY=
